{
  "name": "@anthropic/devlog",
  "version": "0.1.0",
  "description": "Auto-generate dev logs from your Claude Code sessions",
  "type": "module",
  "bin": {
    "devlog": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude",
    "devlog",
    "cli",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dayjs": "^1.11.19",
    "ora": "^9.3.0",
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
